// ========== TYPEWRITER & OPEN/CLOSE HELPERS ==========
function getTypewriterFrames(text, totalFrames) {
  const frames = [];
  const len = text.length;
  if (len === 0) return frames;
  for (let i = 0; i < totalFrames; i++) {
    const progress = (i + 1) / totalFrames;
    const cCount = Math.ceil(progress * len);
    frames.push(text.substring(0, Math.min(cCount, len)));
  }
  return frames;
}

function getOpenCloseFrames(totalFrames) {
  const frames = [];
  for (let i = 0; i < totalFrames; i++) {
    const progress = i / totalFrames;
    frames.push(Math.sin(progress * Math.PI));
  }
  return frames;
}

// ========== DYNAMIC TEXT RENDER ==========
function scheduleRender() {
  if (renderTimeout) clearTimeout(renderTimeout);
  renderTimeout = setTimeout(() => {
    if (currentMode === 'text' && textInput.value.trim()) {
      renderTextToBitmapDynamic();
    }
    renderTimeout = null;
  }, 100);
}

function renderTextToBitmapDynamic() {
  const text = textInput.value.trim();
  if (!text) {
    placeholderText.style.display = 'block';
    workspaceContainer.style.display = 'none';
    return;
  }

  statusBar.style.display = 'none';
  placeholderText.style.display = 'none';
  workspaceContainer.style.display = 'block';
  canvas.style.display = 'block';
  srcImageDisplay.style.display = 'none';
  srcVideoDisplay.style.display = 'none';
  configPanel.classList.add('show');
  selectedBadge.textContent = `Text: "${text.substring(0, 20)}${text.length > 20 ? '...' : ''}"`;

  const temp = document.createElement('canvas');
  const tw = parseInt(bitmapWidthInput.value) || 128;
  const th = parseInt(bitmapHeightInput.value) || 64;
  temp.width = tw;
  temp.height = th;
  const tCtx = temp.getContext('2d');

  tCtx.fillStyle = userBgColor;
  tCtx.fillRect(0, 0, tw, th);

  let desiredSize = parseInt(textSizeRange.value) || 64;
  const fontFamily = fontSelect.value || 'Noto Sans Bengali, sans-serif';

  tCtx.font = `bold ${desiredSize}px ${fontFamily}`;

  const lines = text.split('\n');
  let maxLineWidth = 0;
  lines.forEach(line => {
    const m = tCtx.measureText(line);
    if (m.width > maxLineWidth) maxLineWidth = m.width;
  });

  let maxWidth = tw * 0.92;
  let actualSize = desiredSize;

  while ((maxLineWidth > maxWidth || (lines.length > 1 && lines.length * actualSize * 1.2 > th * 0.85)) && actualSize > 8) {
    actualSize -= 1;
    tCtx.font = `bold ${actualSize}px ${fontFamily}`;
    maxLineWidth = 0;
    lines.forEach(line => {
      const m = tCtx.measureText(line);
      if (m.width > maxLineWidth) maxLineWidth = m.width;
    });
  }

  sizeDisplay.textContent = actualSize + 'px';

  tCtx.font = `bold ${actualSize}px ${fontFamily}`;
  tCtx.textAlign = 'center';
  tCtx.textBaseline = 'middle';
  tCtx.fillStyle = userFgColor;

  if (lines.length === 1) {
    tCtx.fillText(text, tw / 2, th / 2);
  } else {
    const lineHeight = actualSize * 1.2;
    const totalHeight = lines.length * lineHeight;
    const startY = (th - totalHeight) / 2 + actualSize / 2;
    lines.forEach((line, i) => {
      tCtx.fillText(line, tw / 2, startY + i * lineHeight);
    });
  }

  typewriterText = text;
  isTypewriterComplete = false;

  // Text mode never drives the multi-frame timeline strip — only procedural
  // (pulse/spin/typewriter/etc) animation, so we deliberately do NOT call
  // initTimeline()/renderTimeline() here. This is the core bug fix: previously
  // every keystroke re-ran initTimeline(), thrashing the frame strip DOM while
  // the user was actively selecting/editing the textarea.
  timelineFramesData = [];
  document.getElementById('timelineContainer').style.opacity = '0.35';
  document.getElementById('timelineContainer').style.pointerEvents = 'none';

  originalImage = new Image();
  originalImage.onload = () => {
    srcImageDisplay.src = originalImage.src;
    cropToggleBtn.disabled = true;
    cropMetrics = { top: 0, left: 0, width: 100, height: 100 };
    if (isAnimActive) executeRenderLoopEngine();
    else renderFrameToTargetResolution(originalImage);
  };
  originalImage.src = temp.toDataURL();
}

function enableTimelinePanel() {
  document.getElementById('timelineContainer').style.opacity = '1';
  document.getElementById('timelineContainer').style.pointerEvents = 'auto';
}

