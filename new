}
copyBtn.addEventListener('click', () => { codeBox.select(); document.execCommand('copy'); flashCopied(copyBtn); });
copyFullCodeBtn.addEventListener('click', () => { fullCodeBox.select(); document.execCommand('copy'); flashCopied(copyFullCodeBtn); });
copyFullCodeBtn2.addEventListener('click', () => { fullCodeBox.select(); document.execCommand('copy'); flashCopied(copyFullCodeBtn2); });

themeToggle.addEventListener('click', () => {
  if (document.documentElement.getAttribute('data-theme') === 'light') {
    document.documentElement.removeAttribute('data-theme');
  } else {
    document.documentElement.setAttribute('data-theme', 'light');
  }
});

// ========== INIT ==========
placeholderText.style.display = 'block';
workspaceContainer.style.display = 'none';
charCount.textContent = '0 characters';
sizeDisplay.textContent = textSizeRange.value + 'px';
videoFrameCountDisplay.textContent = videoFrameCountRange.value;
