    div.innerHTML = `
      <span class="frame-number">#${index + 1}</span>
      <span class="frame-preview">${frame.emoji || '▢'}</span>
      <span class="frame-delay">${Math.round(animSpeed)}ms</span>
      <button class="delete-frame" data-index="${index}">×</button>
    `;
    div.addEventListener('click', () => {
      selectedFrameIndex = index;
      renderTimeline();
      if ((originalImage || gifFramesData.length) && isAnimActive) executeRenderLoopEngine();
    });
    const delBtn = div.querySelector('.delete-frame');
    delBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (timelineFramesData.length <= 1) { alert('Need at least 1 frame!'); return; }
      timelineFramesData.splice(index, 1);
      if (selectedFrameIndex >= timelineFramesData.length) selectedFrameIndex = timelineFramesData.length - 1;
      renderTimeline();
      if ((originalImage || gifFramesData.length) && isAnimActive) executeRenderLoopEngine();
    });
    timelineFrames.appendChild(div);
  });
  totalFramesDisplay.textContent = `${timelineFramesData.length} frames`;
}

function setActiveFrameVisual(idx) {
  // Lightweight: only flips the 'active' class on existing nodes, does not
  // rebuild the DOM, and only called from the useTimeline playback branch.
  const items = timelineFrames.querySelectorAll('.frame-item');
  items.forEach((el, i) => el.classList.toggle('active', i === idx));
}

function addFrame() {
  const newFrame = { label: `Frame ${timelineFramesData.length + 1}`, emoji: '▢' };
  timelineFramesData.push(newFrame);
  selectedFrameIndex = timelineFramesData.length - 1;
  renderTimeline();
  if ((originalImage || gifFramesData.length) && isAnimActive) executeRenderLoopEngine();
}

function duplicateFrame() {
  if (timelineFramesData.length === 0) return;
  const current = timelineFramesData[selectedFrameIndex];
  const newFrame = { ...current, label: `${current.label} (copy)` };
  timelineFramesData.splice(selectedFrameIndex + 1, 0, newFrame);
  selectedFrameIndex = selectedFrameIndex + 1;
  renderTimeline();
  if ((originalImage || gifFramesData.length) && isAnimActive) executeRenderLoopEngine();
}

function clearFrames() {
  if (timelineFramesData.length <= 1) return;
  if (confirm('Clear all frames except the first?')) {
    const first = timelineFramesData[0];
    timelineFramesData = [first];
    selectedFrameIndex = 0;
    renderTimeline();
    if ((originalImage || gifFramesData.length) && isAnimActive) executeRenderLoopEngine();
  }
}

