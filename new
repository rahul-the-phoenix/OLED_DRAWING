// ========== GIF DECODE ==========
function decodeGifBinaryToFrames(uint8Array) {
  try {
    statusBar.textContent = "Decoding GIF frames...";
    statusBar.style.display = 'block';
    const gifReader = new GifReader(uint8Array);
    const width = gifReader.width; const height = gifReader.height;
    const frameCanvas = document.createElement('canvas');
    frameCanvas.width = width; frameCanvas.height = height;
    const fCtx = frameCanvas.getContext('2d');
    let frameImageData = fCtx.createImageData(width, height);
    gifFramesData = [];
    for (let i = 0; i < gifReader.numFrames(); i++) {
      gifReader.decodeAndBlitFrameRGBA(i, frameImageData.data);
      fCtx.putImageData(frameImageData, 0, 0);
      const cacheCanvas = document.createElement('canvas');
      cacheCanvas.width = width; cacheCanvas.height = height;
      cacheCanvas.getContext('2d').drawImage(frameCanvas, 0, 0);
      gifFramesData.push({ canvas: cacheCanvas, delay: gifReader.frameInfo(i).delay * 10 });
    }
    const frames = gifFramesData.map((f, i) => ({ label: `Frame ${i + 1}`, emoji: '▤', canvas: f.canvas, delay: f.delay }));
    originalImage = gifFramesData[0].canvas;
    initTimeline(frames);
    statusBar.textContent = `${gifFramesData.length} frames loaded.`;
    cropToggleBtn.disabled = true;
    cropMetrics = { top: 0, left: 0, width: 100, height: 100 };
    canvas.style.display = 'block';
    srcImageDisplay.style.display = 'none';
    srcVideoDisplay.style.display = 'none';
    if (isAnimActive) executeRenderLoopEngine();
    else renderFrameToTargetResolution(originalImage);
  } catch (err) {
    alert("Failed decoding GIF.");
    statusBar.style.display = 'none';
  }
}

