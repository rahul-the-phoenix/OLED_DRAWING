<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PixelForge Studio · OLED Asset Compiler</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');

:root{
  --bg:#0a0d09;
  --panel:#10140d;
  --panel-raised:#161b12;
  --line:#232b1d;
  --line-bright:#34402a;
  --phosphor:#bdf2a8;
  --phosphor-dim:#7fa869;
  --signal:#39ff6a;
  --amber:#ff9a3d;
  --amber-dim:#a86423;
  --danger:#ff5d5d;
  --text:#e7f0e0;
  --text-mute:#6d7a63;
  --mono:'IBM Plex Mono', ui-monospace, monospace;
  --sans:'IBM Plex Sans', system-ui, sans-serif;
  --radius:10px;
}
[data-theme="light"]{
  --bg:#eef0e8;
  --panel:#ffffff;
  --panel-raised:#f7f8f3;
  --line:#d8ddcd;
  --line-bright:#b9c2a7;
  --phosphor:#2c5a1e;
  --phosphor-dim:#5a7a4a;
  --signal:#1f8f3f;
  --amber:#c5660f;
  --amber-dim:#a86423;
  --text:#181d12;
  --text-mute:#6f7a62;
}
*{box-sizing:border-box;margin:0;padding:0;font-family:var(--sans);}
body{
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  padding:1.5rem;
  background-image:
    radial-gradient(circle at 15% 10%, rgba(57,255,106,0.04), transparent 40%),
    radial-gradient(circle at 85% 90%, rgba(255,154,61,0.03), transparent 40%);
}
.shell{max-width:1480px;margin:0 auto;}

/* ===== HEADER ===== */
header{
  display:flex;justify-content:space-between;align-items:flex-end;
  padding-bottom:1.1rem;margin-bottom:1.4rem;border-bottom:1px solid var(--line);
  flex-wrap:wrap;gap:1rem;
}
.brand{display:flex;align-items:center;gap:0.9rem;}
.brand-mark{
  width:42px;height:42px;border-radius:8px;background:var(--panel-raised);
  border:1px solid var(--line-bright);display:flex;align-items:center;justify-content:center;
  position:relative;flex-shrink:0;
}
.brand-mark::before{
  content:'';width:18px;height:18px;border-radius:3px;
  background:var(--signal);box-shadow:0 0 12px var(--signal);
  animation:blink 2.2s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1;}48%{opacity:1;}50%{opacity:0.25;}98%{opacity:0.25;}}
.brand h1{
  font-family:var(--mono);font-size:1.4rem;font-weight:700;letter-spacing:-0.01em;
  color:var(--text);
}
.brand h1 span{color:var(--signal);}
.brand p{font-family:var(--mono);font-size:0.72rem;color:var(--text-mute);letter-spacing:0.04em;margin-top:0.15rem;text-transform:uppercase;}
.header-actions{display:flex;gap:0.6rem;align-items:center;}
.icon-btn{
  background:var(--panel-raised);border:1px solid var(--line-bright);color:var(--text);
  padding:0.55rem 1rem;border-radius:7px;cursor:pointer;font-family:var(--mono);font-size:0.78rem;
  font-weight:600;display:flex;align-items:center;gap:0.4rem;transition:all .15s;
}
.icon-btn:hover{border-color:var(--signal);color:var(--signal);}

/* ===== LAYOUT ===== */
.workbench{display:grid;grid-template-columns:460px 1fr;gap:1.4rem;}
@media (max-width:1040px){.workbench{grid-template-columns:1fr;}}

.panel{
  background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);
  padding:1.3rem;display:flex;flex-direction:column;gap:1.1rem;
  position:relative;
}
.panel::before{
  content:'';position:absolute;top:10px;left:10px;width:6px;height:6px;
  border-radius:50%;background:var(--line-bright);
}
.panel-head{
  display:flex;justify-content:space-between;align-items:center;
  padding-bottom:0.85rem;border-bottom:1px solid var(--line);
}
.panel-head h2{
  font-family:var(--mono);font-size:0.72rem;font-weight:700;letter-spacing:0.08em;
  text-transform:uppercase;color:var(--text-mute);display:flex;align-items:center;gap:0.5rem;
}
.panel-head h2 .dot{width:6px;height:6px;border-radius:50%;background:var(--signal);}
.panel-head .meta{font-family:var(--mono);font-size:0.68rem;color:var(--text-mute);}

/* ===== SOURCE TABS ===== */
.source-tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:0.4rem;}
.source-tab{
  padding:0.6rem 0.3rem;text-align:center;font-family:var(--mono);font-size:0.7rem;
  font-weight:600;cursor:pointer;border-radius:7px;color:var(--text-mute);
  background:var(--panel-raised);border:1px solid var(--line);transition:all .15s;
  display:flex;flex-direction:column;align-items:center;gap:0.2rem;
}
.source-tab .ic{font-size:1rem;}
.source-tab.active{background:rgba(57,255,106,0.08);color:var(--signal);border-color:var(--signal);}
.source-tab:hover:not(.active){border-color:var(--line-bright);}
.source-panel{display:none;}
.source-panel.active{display:block;display:flex;flex-direction:column;gap:1rem;}

/* ===== FORM ELEMENTS ===== */
.field{display:flex;flex-direction:column;gap:0.45rem;}
.field label{
  font-family:var(--mono);font-size:0.72rem;font-weight:600;color:var(--text-mute);
  text-transform:uppercase;letter-spacing:0.03em;display:flex;align-items:center;gap:0.4rem;justify-content:space-between;
}
.field label .hint{text-transform:none;font-weight:400;color:var(--text-mute);opacity:0.7;letter-spacing:0;}
.row{display:flex;gap:0.8rem;}
.row .field{flex:1;}
input[type="text"],input[type="number"],select,textarea{
  background:var(--panel-raised);border:1px solid var(--line);color:var(--text);
  padding:0.62rem 0.75rem;border-radius:7px;width:100%;font-size:0.88rem;outline:none;
  font-family:var(--sans);transition:border-color .15s;
}
input[type="text"]:focus,input[type="number"]:focus,select:focus,textarea:focus{border-color:var(--signal);}
textarea{resize:vertical;min-height:64px;font-family:var(--mono);font-size:1.05rem;line-height:1.4;}
input[type="range"]{width:100%;accent-color:var(--signal);cursor:pointer;height:4px;}

.upload-zone{position:relative;width:100%;}
.upload-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;}
.upload-zone-btn{
  background:var(--panel-raised);border:1.5px dashed var(--line-bright);padding:1.5rem 1rem;
  border-radius:9px;text-align:center;color:var(--text-mute);font-size:0.82rem;font-weight:500;
  display:flex;flex-direction:column;align-items:center;gap:0.4rem;transition:border-color .15s;
}
.upload-zone:hover .upload-zone-btn{border-color:var(--signal);color:var(--phosphor);}
.upload-zone-btn .big-ic{font-size:1.6rem;}

.emoji-grid-box{
  background:var(--panel-raised);border:1px solid var(--line);border-radius:9px;height:150px;
  overflow-y:auto;padding:0.5rem;display:grid;grid-template-columns:repeat(7,1fr);gap:0.4rem;
}
.emoji-item{font-size:1.5rem;text-align:center;cursor:pointer;padding:0.2rem;border-radius:6px;transition:transform .1s;}
.emoji-item:hover{transform:scale(1.18);}
.emoji-item.active{background:rgba(57,255,106,0.18);border:1px solid var(--signal);}

.config-panel{
  background:var(--panel-raised);border:1px solid var(--line);border-radius:9px;
  padding:1rem;display:none;flex-direction:column;gap:1rem;animation:fadeIn .25s ease-out;
}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}
.config-panel.show{display:flex;}
.config-badge{
  font-family:var(--mono);font-size:0.76rem;color:var(--signal);background:rgba(57,255,106,0.08);
  padding:0.3rem 0.6rem;border-radius:5px;display:inline-block;border:1px solid rgba(57,255,106,0.25);
}

.color-row{display:flex;gap:0.8rem;}
.color-field{flex:1;display:flex;flex-direction:column;gap:0.4rem;}
input[type="color"]{width:100%;height:34px;border-radius:6px;border:1px solid var(--line);background:var(--panel-raised);cursor:pointer;padding:2px;}
.color-readout{
  display:flex;align-items:center;gap:0.5rem;padding:0.3rem 0.5rem;border-radius:5px;
  border:1px solid var(--line);background:var(--bg);font-family:var(--mono);font-size:0.68rem;color:var(--text-mute);
}
.swatch{width:16px;height:16px;border-radius:3px;border:1px solid var(--line-bright);flex-shrink:0;}

/* toggle pill */
.toggle-pill{
  display:flex;align-items:center;justify-content:space-between;gap:0.8rem;
  background:var(--bg);padding:0.5rem 0.8rem;border-radius:8px;border:1px solid var(--line);
}
.toggle-pill .tp-label{font-size:0.8rem;font-weight:600;display:flex;align-items:center;gap:0.5rem;}
.switch{position:relative;width:38px;height:20px;flex-shrink:0;}
.switch input{opacity:0;width:0;height:0;}
.switch .slider{
  position:absolute;inset:0;background:var(--line-bright);border-radius:20px;cursor:pointer;transition:.2s;
}
.switch .slider::before{
  content:'';position:absolute;width:14px;height:14px;left:3px;top:3px;background:var(--text-mute);
  border-radius:50%;transition:.2s;
}
.switch input:checked + .slider{background:rgba(57,255,106,0.25);}
.switch input:checked + .slider::before{transform:translateX(18px);background:var(--signal);box-shadow:0 0 6px var(--signal);}

/* ===== TIMELINE ===== */
.timeline-box{background:var(--bg);border-radius:9px;padding:0.7rem;border:1px solid var(--line);}
.timeline-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.55rem;font-family:var(--mono);font-size:0.7rem;color:var(--text-mute);}
.timeline-strip{display:flex;gap:0.45rem;overflow-x:auto;padding:0.2rem 0.1rem;}
.frame-item{
  min-width:54px;padding:0.4rem;background:var(--panel-raised);border-radius:6px;text-align:center;
  cursor:pointer;border:1.5px solid var(--line);position:relative;transition:all .15s;
}
.frame-item.active{border-color:var(--signal);background:rgba(57,255,106,0.1);}
.frame-item:hover{border-color:var(--line-bright);}
.frame-number{font-family:var(--mono);font-size:0.62rem;font-weight:700;color:var(--text-mute);display:block;}
.frame-item.active .frame-number{color:var(--signal);}
.frame-preview{font-size:1.1rem;display:block;margin:2px 0;}
.frame-delay{font-family:var(--mono);font-size:0.56rem;color:var(--text-mute);opacity:0.7;}
.delete-frame{
  position:absolute;top:-6px;right:-6px;background:var(--danger);color:#fff;border:none;
  border-radius:50%;width:16px;height:16px;font-size:9px;cursor:pointer;display:none;line-height:16px;
}
.frame-item:hover .delete-frame{display:block;}
.timeline-controls{display:flex;gap:0.4rem;margin-top:0.55rem;flex-wrap:wrap;align-items:center;}
.mini-btn{
  padding:0.32rem 0.7rem;font-size:0.68rem;border-radius:5px;border:1px solid var(--line);
  background:var(--panel-raised);color:var(--text-mute);cursor:pointer;font-family:var(--mono);font-weight:600;
}
.mini-btn:hover{border-color:var(--signal);color:var(--signal);}
.speed-ctl{display:flex;align-items:center;gap:0.5rem;flex:1;min-width:140px;}
.speed-ctl span{font-family:var(--mono);font-size:0.7rem;color:var(--text-mute);min-width:42px;}

/* ===== BUTTONS ===== */
.btn{
  background:var(--signal);color:#06140a;border:none;padding:0.7rem 1.2rem;border-radius:8px;
  font-weight:700;font-size:0.85rem;cursor:pointer;display:inline-flex;align-items:center;
  justify-content:center;gap:0.5rem;transition:all .15s;font-family:var(--mono);
}
.btn:hover{box-shadow:0 0 16px rgba(57,255,106,0.35);transform:translateY(-1px);}
.btn:disabled{opacity:0.4;cursor:not-allowed;box-shadow:none;transform:none;}
.btn-secondary{background:var(--panel-raised);color:var(--text);border:1px solid var(--line-bright);}
.btn-secondary:hover{box-shadow:none;border-color:var(--signal);color:var(--signal);}
.btn-amber{background:var(--amber);color:#1c0d00;}
.btn-amber:hover{box-shadow:0 0 16px rgba(255,154,61,0.35);}
.btn-crop-active{background:var(--danger) !important;color:#fff !important;}
.btn-row{display:flex;gap:0.6rem;flex-wrap:wrap;}
.btn-row > *{flex:1;}

/* ===== PREVIEW / SCREEN ===== */
.screen-wrap{
  background:#000;border-radius:12px;border:6px solid var(--panel-raised);
  outline:1px solid var(--line-bright);min-height:420px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;position:relative;overflow:hidden;
}
.screen-wrap::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:repeating-linear-gradient(0deg, rgba(0,0,0,0.18) 0px, rgba(0,0,0,0.18) 1px, transparent 1px, transparent 3px);
  mix-blend-mode:multiply;opacity:0.5;
}
.screen-status{
  position:absolute;top:10px;left:12px;display:flex;align-items:center;gap:0.4rem;z-index:5;
  font-family:var(--mono);font-size:0.62rem;color:var(--signal);text-transform:uppercase;letter-spacing:0.05em;
}
.screen-status .led{width:6px;height:6px;border-radius:50%;background:var(--signal);box-shadow:0 0 6px var(--signal);animation:blink 1.8s infinite;}
.screen-dims{position:absolute;top:10px;right:12px;font-family:var(--mono);font-size:0.62rem;color:var(--text-mute);z-index:5;}

.workspace-inner{position:relative;display:inline-block;}
#srcImageDisplay,#srcVideoDisplay{max-width:100%;max-height:400px;display:none;user-select:none;-webkit-user-drag:none;}
#previewCanvas{max-width:100%;max-height:400px;image-rendering:pixelated;display:block;}
.crop-box-pro{position:absolute;border:1px solid #fff;outline:2000px solid rgba(0,0,0,0.7);cursor:move;display:none;box-shadow:0 0 20px rgba(0,0,0,0.85);}
.handle-pro{position:absolute;width:10px;height:10px;background:#fff;border:1px solid #000;}
.h-tl{top:-5px;left:-5px;cursor:nwse-resize;}
.h-tr{top:-5px;right:-5px;cursor:nesw-resize;}
.h-bl{bottom:-5px;left:-5px;cursor:nesw-resize;}
.h-br{bottom:-5px;right:-5px;cursor:nwse-resize;}
.placeholder-text{color:var(--text-mute);font-size:0.95rem;padding:2rem;text-align:center;font-family:var(--mono);}

.video-scrub-bar{
  position:absolute;bottom:8px;left:8px;right:8px;z-index:6;display:none;
  background:rgba(0,0,0,0.55);border-radius:6px;padding:0.4rem 0.6rem;align-items:center;gap:0.5rem;
}
.video-scrub-bar.show{display:flex;}
.video-scrub-bar input[type="range"]{flex:1;accent-color:var(--signal);}
.video-scrub-bar span{font-family:var(--mono);font-size:0.62rem;color:var(--phosphor);min-width:38px;}

/* ===== TABS (output) ===== */
.out-tabs{display:flex;gap:0.4rem;}
.out-tab{
  padding:0.5rem 1rem;border-radius:8px 8px 0 0;cursor:pointer;background:var(--panel-raised);
  font-family:var(--mono);font-size:0.76rem;color:var(--text-mute);font-weight:600;border:1px solid var(--line);
  border-bottom:none;
}
.out-tab.active{background:var(--panel);color:var(--signal);border-color:var(--line-bright);}

.code-shell{background:#000;border-radius:0 0 10px 10px;border:1px solid var(--line-bright);flex-grow:1;display:flex;flex-direction:column;overflow:hidden;margin-top:-1px;}
textarea.code-area{
  background:transparent;border:none;color:var(--phosphor);font-family:var(--mono);padding:1rem;
  resize:none;width:100%;height:100%;outline:none;font-size:0.78rem;line-height:1.55;min-height:480px;
}
.code-foot{padding:0.7rem 1rem;background:var(--panel-raised);border-top:1px solid var(--line);display:flex;justify-content:flex-end;gap:0.5rem;}

.status-line{
  font-family:var(--mono);font-size:0.78rem;color:var(--signal);font-weight:600;display:none;
  background:rgba(57,255,106,0.06);border:1px solid rgba(57,255,106,0.2);padding:0.5rem 0.8rem;border-radius:6px;
}
.char-count{font-family:var(--mono);font-size:0.68rem;color:var(--text-mute);text-align:right;}
.size-readout{
  font-family:var(--mono);min-width:54px;text-align:center;font-weight:700;color:var(--signal);
  background:var(--bg);padding:2px 8px;border-radius:5px;font-size:0.78rem;border:1px solid var(--line);
}
</style>
<script src="https://cdn.jsdelivr.net/npm/omggif@1.0.10/omggif.min.js"></script>
</head>
<body>
<div class="shell">

<header>
  <div class="brand">
    <div class="brand-mark"></div>
    <div>
      <h1>PixelForge<span>::Studio</span></h1>
      <p>OLED bitmap &amp; animation compiler — text · image · sticker · video</p>
    </div>
  </div>
  <div class="header-actions">
    <button class="icon-btn" id="themeToggle">◐ Display mode</button>
    <button class="icon-btn" id="exportZipBtn">⇣ Export .zip</button>
  </div>
</header>

<div class="workbench">

  <!-- ============ INPUT PANEL ============ -->
  <div class="panel">
    <div class="panel-head">
      <h2><span class="dot"></span>Input source</h2>
      <span class="meta">auto-render</span>
    </div>

    <div class="source-tabs">
      <div class="source-tab active" data-source="text"><span class="ic">✎</span>Text</div>
      <div class="source-tab" data-source="file"><span class="ic">▣</span>Image</div>
      <div class="source-tab" data-source="video"><span class="ic">▶</span>Video</div>
      <div class="source-tab" data-source="emoji"><span class="ic">☺</span>Sticker</div>
    </div>

    <!-- TEXT -->
    <div class="source-panel active" id="panel-text">
      <div class="row">
        <div class="field">
          <label>Language</label>
          <select id="languageSelect">
            <option value="en">EN — English</option>
            <option value="hi">HI — हिंदी</option>
            <option value="bn">BN — বাংলা</option>
            <option value="ta">TA — தமிழ்</option>
            <option value="ur">UR — اردو</option>
          </select>
        </div>
        <div class="field">
          <label>Typeface</label>
          <select id="fontSelect"></select>
        </div>
      </div>
      <div class="field">
        <label>Message <span class="hint">updates live as you type</span></label>
        <textarea id="textInput" placeholder="Type here... e.g. Hello / নমস্কার" rows="2"></textarea>
        <div class="char-count" id="charCount">0 characters</div>
      </div>
      <div class="field">
        <label>Glyph size <span class="size-readout" id="sizeDisplay">64px</span></label>
        <input type="range" id="textSizeRange" min="8" max="300" value="64" step="1">
      </div>
    </div>

    <!-- IMAGE -->
    <div class="source-panel" id="panel-file">
      <div class="upload-zone">
        <input type="file" id="imageLoader" accept="image/*,image/gif" multiple>
        <div class="upload-zone-btn"><span class="big-ic">⇡</span>Drop images, GIFs, or stickers — multiple files become frames</div>
      </div>
    </div>

    <!-- VIDEO -->
    <div class="source-panel" id="panel-video">
      <div class="upload-zone">
        <input type="file" id="videoLoader" accept="video/*">
        <div class="upload-zone-btn"><span class="big-ic">⇡</span>Drop a video file — frames are sampled automatically</div>
      </div>
      <div class="field" id="videoFrameCountField" style="display:none;">
        <label>Sampled frames <span class="size-readout" id="videoFrameCountDisplay">12</span></label>
        <input type="range" id="videoFrameCountRange" min="2" max="30" value="12" step="1">
      </div>
    </div>

    <!-- EMOJI / STICKER -->
    <div class="source-panel" id="panel-emoji">
      <div class="field">
        <label>Sticker pack</label>
        <select id="emojiCategorySelect"></select>
        <div class="emoji-grid-box" id="emojiGrid"></div>
      </div>
    </div>

    <!-- DYNAMIC CONFIG -->
    <div class="config-panel" id="configPanel">
      <span class="config-badge" id="selectedBadge">Text mode</span>

      <div class="field">
        <label>Animation style</label>
        <select id="animType">
          <option value="none">— Static, no motion</option>
          <option value="pulse">Pulse — expands &amp; contracts</option>
          <option value="spin">Spin — rotates 360°</option>
          <option value="bounce">Bounce — up &amp; down</option>
          <option value="shake">Shake — left &amp; right</option>
          <option value="flicker">Flicker — brightness flashes</option>
          <option value="wave">Wave — undulation</option>
          <option value="zoom">Zoom — scales in/out</option>
          <option value="skew">Skew — slant tilt</option>
          <option value="blink">Blink — vertical squash</option>
          <option value="morph">Morph — stretch horizontal</option>
          <option value="glow">Glow — fade in/out</option>
          <option value="drift">Drift — gentle floating</option>
          <option value="slideUp">Slide up — enters from bottom</option>
          <option value="slideDown">Slide down — enters from top</option>
          <option value="slideLeft">Slide left — enters from right</option>
          <option value="slideRight">Slide right — enters from left</option>
          <option value="slideDiagonal">Slide diagonal — from corner</option>
          <option value="scrollUp">Scroll up — marquee</option>
          <option value="scrollDown">Scroll down — marquee</option>
          <option value="scrollLeft">Scroll left — marquee</option>
          <option value="scrollRight">Scroll right — marquee</option>
          <option value="vanish">Vanish — fades &amp; shrinks</option>
          <option value="explode">Explode — bursts outward</option>
          <option value="implode">Implode — collapses inward</option>
          <option value="swing">Swing — pendulum motion</option>
          <option value="tilt">Tilt — rotates back &amp; forth</option>
