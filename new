  if (videoElement && videoElement.duration) {
    clearTimeout(window._vfcDebounce);
    window._vfcDebounce = setTimeout(() => extractVideoFrames(), 220);
  }
});

videoScrubRange.addEventListener('input', function () {
  if (!videoElement) return;
  clearInterval(activeRenderPlaybackInterval);
  const t = parseFloat(this.value);
  videoScrubTime.textContent = t.toFixed(1) + 's';
  seekVideoTo(t).then(() => {
    if (isCropMode) {
      // show live video frame behind the crop box
      srcVideoDisplay.style.display = 'block';
      canvas.style.display = 'none';
    } else {
      renderFrameToTargetResolution(videoElement);
    }
  });
});

function seekVideoTo(t) {
  return new Promise((resolve) => {
    const onSeeked = () => { videoElement.removeEventListener('seeked', onSeeked); resolve(); };
    videoElement.addEventListener('seeked', onSeeked);
    videoElement.currentTime = Math.min(Math.max(t, 0), videoElement.duration);
  });
}

async function extractVideoFrames() {
  if (!videoElement || !videoElement.duration) return;
  clearInterval(activeRenderPlaybackInterval);
  const duration = videoElement.duration;
  const n = videoFrameCount;
  const wasPlaying = false;
  videoElement.pause();

  const frames = [];
  videoFramesExtracted = [];
  for (let i = 0; i < n; i++) {
    const t = (n === 1) ? 0 : (i / (n - 1)) * duration * 0.999;
    await seekVideoTo(t);
    const w = videoElement.videoWidth, h = videoElement.videoHeight;
    const cap = document.createElement('canvas');
    cap.width = w; cap.height = h;
    cap.getContext('2d').drawImage(videoElement, 0, 0, w, h);
    videoFramesExtracted.push(cap);
    frames.push({ label: `Frame ${i + 1}`, emoji: '▶', canvas: cap });
  }

  originalImage = videoFramesExtracted[0];
  initTimeline(frames);
  statusBar.textContent = `${n} frames sampled from video.`;
  setTimeout(() => statusBar.style.display = 'none', 2500);

  srcVideoDisplay.style.display = 'none';
  canvas.style.display = 'block';
  if (!isCropMode) {
    if (isAnimActive) executeRenderLoopEngine();
    else renderFrameToTargetResolution(originalImage);
  }
}

// ========== RENDER ENGINE ==========
function executeRenderLoopEngine() {
  clearInterval(activeRenderPlaybackInterval);
  if (!isAnimActive) {
    if (originalImage) renderFrameToTargetResolution(originalImage);
    return;
  }

  canvas.style.display = 'block';
  workspaceContainer.style.display = 'block';
  placeholderText.style.display = 'none';

  const motionFX = animTypeSelect.value;
  const isGifActive = gifFramesData.length > 0;
  const isProceduralActive = (motionFX !== 'none' && originalImage);
  const useTimeline = timelineFramesData.length > 1 && !isGifActive;

  if (!originalImage && gifFramesData.length === 0) return;

  // Typewriter (text mode only)
  if (motionFX === 'typewriter' && currentMode === 'text' && originalImage) {
    const text = typewriterText || textInput.value.trim();
    if (text) {
      const totalFrames = Math.min(text.length, 30);
      const typewriterFramesArr = getTypewriterFrames(text, totalFrames);
      if (typewriterFramesArr.length > 0) {
        activePlaybackIndex = 0;
        isTypewriterComplete = false;
        activeRenderPlaybackInterval = setInterval(() => {
          const frameText = typewriterFramesArr[activePlaybackIndex % typewriterFramesArr.length];
          const isLastFrame = (activePlaybackIndex >= typewriterFramesArr.length - 1);
          if (isLastFrame) isTypewriterComplete = true;
          const showCursor = !isTypewriterComplete;
          renderTypewriterFrame(frameText, text, showCursor);
          activePlaybackIndex = (activePlaybackIndex + 1) % typewriterFramesArr.length;
          if (activePlaybackIndex === 0 && isTypewriterComplete) isTypewriterComplete = false;
        }, animSpeed);
        return;
      }
    }
  }

  // Open/close (works on any single source)
  if (motionFX === 'openClose' && originalImage) {
    const totalFrames = 8;
    const openCloseValues = getOpenCloseFrames(totalFrames);
    activePlaybackIndex = 0;
    activeRenderPlaybackInterval = setInterval(() => {
      const progress = openCloseValues[activePlaybackIndex % openCloseValues.length];
      renderOpenCloseFrame(originalImage, progress);
      activePlaybackIndex = (activePlaybackIndex + 1) % openCloseValues.length;
    }, animSpeed);
    return;
  }

  if (isGifActive) {
    activePlaybackIndex = 0;
    activeRenderPlaybackInterval = setInterval(() => {
      const frame = gifFramesData[activePlaybackIndex] || gifFramesData[0];
      renderFrameToTargetResolution(frame.canvas);
      activePlaybackIndex = (activePlaybackIndex + 1) % gifFramesData.length;
    }, gifFramesData[0].delay || animSpeed);
  } else if (useTimeline) {
    activePlaybackIndex = 0;
    activeRenderPlaybackInterval = setInterval(() => {
      const frameData = timelineFramesData[activePlaybackIndex];
      if (frameData.image) {
        renderFrameToTargetResolution(frameData.image);
      } else if (frameData.canvas) {
        renderFrameToTargetResolution(frameData.canvas);
      } else {
        renderFrameToTargetResolution(originalImage, { type: motionFX, step: activePlaybackIndex });
      }
      // Only place the playback loop is allowed to touch frame-item DOM —
      // and only in this branch, which strictly means we ARE animating a real
      // multi-frame source (images/gif/video), never the text textarea.
      setActiveFrameVisual(activePlaybackIndex);
      activePlaybackIndex = (activePlaybackIndex + 1) % timelineFramesData.length;
    }, animSpeed);
  } else if (isProceduralActive) {
    activePlaybackIndex = 0;
    activeRenderPlaybackInterval = setInterval(() => {
      renderFrameToTargetResolution(originalImage, { type: motionFX, step: activePlaybackIndex });
      activePlaybackIndex = (activePlaybackIndex + 1) % 4;
    }, animSpeed);
  } else if (originalImage) {
    renderFrameToTargetResolution(originalImage);
  }
}

// ========== TYPEWRITER RENDER ==========
function renderTypewriterFrame(displayText, fullText, showCursor) {
  const tw = parseInt(bitmapWidthInput.value) || 128;
  const th = parseInt(bitmapHeightInput.value) || 64;
  const threshold = parseInt(thresholdRange.value);
  document.querySelector('#thresholdLabel .size-readout').textContent = threshold;
  canvas.width = tw; canvas.height = th;

  const temp = document.createElement('canvas');
  temp.width = tw; temp.height = th;
  const tCtx = temp.getContext('2d');

  tCtx.fillStyle = userBgColor;
  tCtx.fillRect(0, 0, tw, th);

  let actualSize = parseInt(textSizeRange.value) || 64;
  const fontFamily = fontSelect.value || 'Noto Sans Bengali, sans-serif';
  tCtx.font = `bold ${actualSize}px ${fontFamily}`;
  tCtx.textAlign = 'center';
  tCtx.textBaseline = 'middle';
  tCtx.fillStyle = userFgColor;

  const lines = displayText.split('\n');
  if (lines.length === 1) {
    const textWithCursor = showCursor ? displayText + '█' : displayText;
    tCtx.fillText(textWithCursor, tw / 2, th / 2);
  } else {
    const lineHeight = actualSize * 1.2;
    const totalHeight = lines.length * lineHeight;
    const startY = (th - totalHeight) / 2 + actualSize / 2;
    lines.forEach((line, i) => {
      const isLastLine = (i === lines.length - 1);
      const textWithCursor = (isLastLine && showCursor) ? line + '█' : line;
      tCtx.fillText(textWithCursor, tw / 2, startY + i * lineHeight);
    });
  }

  commitThresholdedFrame(tCtx, tw, th, threshold);
}

// ========== OPEN/CLOSE RENDER ==========
function renderOpenCloseFrame(sourceAsset, progress) {
  const tw = parseInt(bitmapWidthInput.value) || 128;
  const th = parseInt(bitmapHeightInput.value) || 64;
  const threshold = parseInt(thresholdRange.value);
  document.querySelector('#thresholdLabel .size-readout').textContent = threshold;
  canvas.width = tw; canvas.height = th;

  const temp = document.createElement('canvas');
  temp.width = tw; temp.height = th;
  const tCtx = temp.getContext('2d');

  tCtx.fillStyle = userBgColor;
  tCtx.fillRect(0, 0, tw, th);

  const scaleX = Math.max(0.05, progress);
  const scaleY = Math.max(0.05, 1 - (1 - progress) * 0.5);

  const dims = getSourceDims(sourceAsset);
  const sX = (cropMetrics.left / 100) * dims.w;
  const sY = (cropMetrics.top / 100) * dims.h;
  const sW = (cropMetrics.width / 100) * dims.w;
  const sH = (cropMetrics.height / 100) * dims.h;

  tCtx.save();
  tCtx.translate(tw / 2, th / 2);
  tCtx.scale(scaleX, scaleY);
  tCtx.translate(-tw / 2, -th / 2);
  tCtx.drawImage(sourceAsset, sX, sY, sW, sH, 0, 0, tw, th);
  tCtx.restore();

  commitThresholdedFrame(tCtx, tw, th, threshold);
}

function getSourceDims(asset) {
  if (!asset) return { w: 0, h: 0 };
  if (asset.videoWidth) return { w: asset.videoWidth, h: asset.videoHeight };
  if (asset.naturalWidth) return { w: asset.naturalWidth, h: asset.naturalHeight };
  return { w: asset.width, h: asset.height };
}

// ========== STANDARD RENDER ==========
function renderFrameToTargetResolution(sourceAsset, fxSpecs = null) {
  if (!sourceAsset) return;
  if (isCropMode) {
    canvas.style.display = 'none';
    if (currentMode === 'video') {
      srcVideoDisplay.style.display = 'block';
      srcImageDisplay.style.display = 'none';
    } else {
      srcImageDisplay.style.display = 'block';
      srcVideoDisplay.style.display = 'none';
    }
    return;
  }

  canvas.style.display = 'block';
  srcImageDisplay.style.display = 'none';
  srcVideoDisplay.style.display = 'none';

  const tw = parseInt(bitmapWidthInput.value) || 128;
  const th = parseInt(bitmapHeightInput.value) || 64;
  const threshold = parseInt(thresholdRange.value);
  document.querySelector('#thresholdLabel .size-readout').textContent = threshold;
  canvas.width = tw; canvas.height = th;

  const temp = document.createElement('canvas');
  temp.width = tw; temp.height = th;
  const tCtx = temp.getContext('2d');

  tCtx.fillStyle = userBgColor;
  tCtx.fillRect(0, 0, tw, th);

  const dims = getSourceDims(sourceAsset);
  const sX = (cropMetrics.left / 100) * dims.w;
  const sY = (cropMetrics.top / 100) * dims.h;
  const sW = (cropMetrics.width / 100) * dims.w;
  const sH = (cropMetrics.height / 100) * dims.h;

  tCtx.save();

  if (fxSpecs) {
    const step = fxSpecs.step;
    const t = step / 4;
    const angle = t * Math.PI * 2;
    let tx = 0, ty = 0, scX = 1, scY = 1, rot = 0, alpha = 1, skewX = 0, skewY = 0;

    switch (fxSpecs.type) {
      case 'pulse': { let s = 0.85 + 0.15 * Math.sin(angle); scX = s; scY = s; break; }
      case 'spin': { rot = step * 90 * Math.PI / 180; break; }
      case 'bounce': { ty = (step % 2 === 0) ? -5 : 5; if (step === 0 || step === 3) ty = 0; break; }
      case 'shake': { tx = (step % 2 === 0) ? -4 : 4; break; }
      case 'flicker': { if (step === 1 || step === 3) alpha = 0.6; break; }
      case 'wave': { ty = Math.sin(step * 1.2) * 6; break; }
      case 'zoom': { let s = 0.8 + 0.2 * Math.sin(angle + 1); scX = s; scY = s; break; }
      case 'skew': { skewX = 0.1 * Math.sin(angle); break; }
      case 'blink': { scY = (step === 1 || step === 3) ? 0.3 : 1; break; }
      case 'morph': { scX = 1 + 0.2 * Math.sin(angle); scY = 1 - 0.2 * Math.sin(angle); break; }
      case 'glow': { alpha = 0.7 + 0.3 * Math.sin(angle + 0.5); break; }
      case 'drift': { tx = 4 * Math.sin(angle + 1.2); ty = 3 * Math.cos(angle + 0.8); break; }
      case 'slideUp': { ty = -20 + 20 * (1 - t); break; }
      case 'slideDown': { ty = 20 - 20 * (1 - t); break; }
      case 'slideLeft': { tx = -20 + 20 * (1 - t); break; }
      case 'slideRight': { tx = 20 - 20 * (1 - t); break; }
      case 'slideDiagonal': { tx = -15 + 15 * (1 - t); ty = -15 + 15 * (1 - t); break; }
      case 'scrollRight': { let p = t * 2; if (p > 1) p -= 2; tx = -100 + (p * 200); break; }
      case 'scrollLeft': { let p = t * 2; if (p > 1) p -= 2; tx = 100 - (p * 200); break; }
      case 'scrollUp': { let p = t * 2; if (p > 1) p -= 2; ty = 100 - (p * 200); break; }
      case 'scrollDown': { let p = t * 2; if (p > 1) p -= 2; ty = -100 + (p * 200); break; }
      case 'vanish': { let v = 1 - t; scX = v; scY = v; alpha = v; break; }
      case 'explode': { let e = 1 + t * 0.4; scX = e; scY = e; alpha = 1 - t * 0.3; break; }
      case 'implode': { let e = 1 - t * 0.3; scX = e; scY = e; alpha = 1 - t * 0.2; break; }
      case 'swing': { rot = 0.15 * Math.sin(angle * 1.5); break; }
      case 'tilt': { rot = 0.2 * Math.sin(angle * 2); skewX = 0.05 * Math.sin(angle * 2); break; }
      case 'ripple': { skewX = 0.08 * Math.sin(angle * 3); skewY = 0.05 * Math.cos(angle * 2); break; }
      default: break;
    }

    tCtx.translate(tw / 2, th / 2);
    tCtx.translate(tx, ty);
    tCtx.scale(scX, scY);
    tCtx.rotate(rot);
    if (skewX !== 0 || skewY !== 0) tCtx.transform(1, skewY, skewX, 1, 0, 0);
    tCtx.globalAlpha = alpha;
    tCtx.translate(-tw / 2, -th / 2);
  }

  tCtx.drawImage(sourceAsset, sX, sY, sW, sH, 0, 0, tw, th);
  tCtx.restore();

  commitThresholdedFrame(tCtx, tw, th, threshold);
}

function commitThresholdedFrame(tCtx, tw, th, threshold) {
  const imgData = tCtx.getImageData(0, 0, tw, th);
  const d = imgData.data;
  const invert = !pixelToggle.checked;
  for (let i = 0; i < d.length; i += 4) {
    let luminance = (d[i + 3] < 30) ? 0 : (0.2126 * d[i] + 0.7152 * d[i + 1] + 0.0722 * d[i + 2]);
    let col = (luminance >= threshold) ? 255 : 0;
    if (invert) col = col === 0 ? 255 : 0;
    d[i] = col; d[i + 1] = col; d[i + 2] = col; d[i + 3] = 255;
  }
  ctx.putImageData(imgData, 0, 0);
  currentArrayData = parseCanvasBytesToHexRowString(tw, th, threshold);
}

// ========== ZIP EXPORT ==========
function exportToZip() {
  if (!originalImage && gifFramesData.length === 0) {
    alert('Please load an asset first!');
    return;
  }

  const tw = parseInt(bitmapWidthInput.value) || 128;
  const th = parseInt(bitmapHeightInput.value) || 64;
  const threshold = parseInt(thresholdRange.value);
  const varName = variableNameInput.value.trim() || "TextAsset";
  const motionFX = animTypeSelect.value;
  const useTimeline = timelineFramesData.length > 1 && gifFramesData.length === 0;
  let totalFrames = 1;

  if (gifFramesData.length > 0) totalFrames = gifFramesData.length;
  else if (useTimeline) totalFrames = timelineFramesData.length;
  else if (motionFX !== 'none' && motionFX !== 'typewriter' && motionFX !== 'openClose') totalFrames = 4;
  else if (motionFX === 'typewriter') totalFrames = Math.min(typewriterText.length, 30);
  else if (motionFX === 'openClose') totalFrames = 8;

  clearInterval(activeRenderPlaybackInterval);

  let allFrameData = [];
  let frameNames = [];

  for (let f = 0; f < totalFrames; f++) {
    let source;
    if (gifFramesData.length > 0) {
      source = gifFramesData[f % gifFramesData.length].canvas;
    } else if (useTimeline) {
      const fd = timelineFramesData[f % timelineFramesData.length];
      source = fd.image || fd.canvas || originalImage;
    } else {
      source = originalImage;
    }

    if (motionFX === 'typewriter' && currentMode === 'text') {
      const text = typewriterText || textInput.value.trim();
      const frames = getTypewriterFrames(text, totalFrames);
      const frameText = frames[f % frames.length] || text;
      renderTypewriterFrame(frameText, text, false);
    } else if (motionFX === 'openClose') {
      const values = getOpenCloseFrames(totalFrames);
      renderOpenCloseFrame(source, values[f % values.length]);
    } else if (motionFX !== 'none' && gifFramesData.length === 0 && !useTimeline) {
      renderFrameToTargetResolution(source, { type: motionFX, step: f });
    } else {
      renderFrameToTargetResolution(source);
    }

    const hexData = parseCanvasBytesToHexRowString(tw, th, threshold);
    const name = (totalFrames === 1) ? varName : `${varName}_frame_${f}`;
    frameNames.push(name);
    allFrameData.push({ name, data: hexData });
  }

  let arrayOutput = '';
  allFrameData.forEach((fd) => {
    arrayOutput += `static const uint8_t PROGMEM ${fd.name}[] = {\n  ${fd.data}\n};\n\n`;
  });

  let animTable = '';
  if (totalFrames > 1) {
    animTable = `static const uint8_t* const ${varName}_Anim[] PROGMEM = {\n  ${frameNames.join(", ")}\n};\n`;
  }

  const fullCode = buildFullSketch(varName, tw, th, totalFrames, motionFX, arrayOutput, animTable);

  if (typeof JSZip === 'undefined') {
    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
    script.onload = () => createZipFile(fullCode, arrayOutput, varName, tw, th);
    document.head.appendChild(script);
  } else {
    createZipFile(fullCode, arrayOutput, varName, tw, th);
  }
}

function buildFullSketch(varName, tw, th, totalFrames, motionFX, arrayOutput, animTable) {
  return `/*
 * PixelForge Studio — generated asset
 * Size: ${tw}x${th} | Frames: ${totalFrames} | Speed: ${animSpeed}ms
 * Animation: ${motionFX}
 * Colors: BG=${userBgColor}, FG=${userFgColor}
 * Generated: ${new Date().toLocaleString()}
 */

#include <SPI.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH ${tw}
#define SCREEN_HEIGHT ${th}
#define OLED_ADDRESS 0x3C
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

${arrayOutput}${animTable}

void setup() {
  Serial.begin(115200);
  if(!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDRESS)) {
    Serial.println("SSD1306 allocation failed");
    for(;;);
  }
  display.clearDisplay();
  display.display();
}

void loop() {
  display.clearDisplay();
  ${totalFrames > 1 ? `static int frameIndex = 0;
  display.drawBitmap(0, 0, ${varName}_Anim[frameIndex], SCREEN_WIDTH, SCREEN_HEIGHT, 1);
  frameIndex = (frameIndex + 1) % ${totalFrames};` : `display.drawBitmap(0, 0, ${varName}, SCREEN_WIDTH, SCREEN_HEIGHT, 1);`}
  display.display();
  delay(${animSpeed});
}`;
}

function createZipFile(fullCode, arrayData, varName, tw, th) {
  const zip = new JSZip();
  zip.file(`${varName}_full_code.ino`, fullCode);
  const headerContent = `// ${varName}.h - Bitmap data\n#ifndef ${varName.toUpperCase()}_H\n#define ${varName.toUpperCase()}_H\n\n${arrayData}\n#endif`;
  zip.file(`${varName}.h`, headerContent);
  const info = `PixelForge Studio Export
========================
Asset: ${varName}
Size: ${tw}x${th}
Frames: ${timelineFramesData.length || 1}
Animation Speed: ${animSpeed}ms
Colors: BG=${userBgColor}, FG=${userFgColor}
Generated: ${new Date().toLocaleString()}
========================
`;
  zip.file('README.txt', info);

  zip.generateAsync({ type: 'blob' }).then((content) => {
    const link = document.createElement('a');
    link.download = `${varName}_pixelforge_export.zip`;
    link.href = URL.createObjectURL(content);
    link.click();
    URL.revokeObjectURL(link.href);
    statusBar.textContent = 'ZIP exported successfully.';
    statusBar.style.display = 'block';
    setTimeout(() => statusBar.style.display = 'none', 3000);
  });
}

// ========== CODE GENERATION ==========
function generateHardwareOutputCode() {
  if (isCropMode) disableCropModeUI();
  if (!originalImage && gifFramesData.length === 0) {
    codeBox.value = "// Load an asset first!";
    fullCodeBox.value = "// Load an asset first!";
    switchTab('code');
    return;
  }

  if (originalImage) renderFrameToTargetResolution(originalImage);

  const tw = canvas.width; const th = canvas.height;
  const threshold = parseInt(thresholdRange.value);
  const varName = variableNameInput.value.trim() || "TextAsset";
  const motionFX = animTypeSelect.value;
  const useTimeline = timelineFramesData.length > 1 && gifFramesData.length === 0;
  let totalFrames = 1;

  if (gifFramesData.length > 0) totalFrames = gifFramesData.length;
  else if (useTimeline) totalFrames = timelineFramesData.length;
  else if (motionFX !== 'none' && motionFX !== 'typewriter' && motionFX !== 'openClose') totalFrames = 4;
  else if (motionFX === 'typewriter') totalFrames = Math.min(typewriterText.length, 30);
  else if (motionFX === 'openClose') totalFrames = 8;

  let arrayOutput = '';
  let generatedArrayTableNames = [];
  clearInterval(activeRenderPlaybackInterval);

  for (let f = 0; f < totalFrames; f++) {
    let source;
    if (gifFramesData.length > 0) {
      source = gifFramesData[f % gifFramesData.length].canvas;
    } else if (useTimeline) {
      const fd = timelineFramesData[f % timelineFramesData.length];
      source = fd.image || fd.canvas || originalImage;
    } else {
      source = originalImage;
    }

    if (motionFX === 'typewriter' && currentMode === 'text') {
      const text = typewriterText || textInput.value.trim();
      const frames = getTypewriterFrames(text, totalFrames);
      const frameText = frames[f % frames.length] || text;
      renderTypewriterFrame(frameText, text, false);
    } else if (motionFX === 'openClose') {
      const values = getOpenCloseFrames(totalFrames);
      renderOpenCloseFrame(source, values[f % values.length]);
    } else if (motionFX !== 'none' && gifFramesData.length === 0 && !useTimeline) {
      renderFrameToTargetResolution(source, { type: motionFX, step: f });
    } else {
      renderFrameToTargetResolution(source);
    }

    let currentFrameVarName = (totalFrames === 1) ? varName : `${varName}_frame_${f}`;
    generatedArrayTableNames.push(currentFrameVarName);
    arrayOutput += `static const uint8_t PROGMEM ${currentFrameVarName}[] = {\n  `;
    const hexData = parseCanvasBytesToHexRowString(tw, th, threshold);
    arrayOutput += hexData;
    arrayOutput += "\n};\n\n";
  }

  let animTable = '';
  if (totalFrames > 1) {
    animTable = `// Animation frame lookup table\n`;
    animTable += `static const uint8_t* const ${varName}_Anim[] PROGMEM = {\n  `;
    animTable += generatedArrayTableNames.join(", ") + "\n};\n";
  }

  const fullCode = buildFullSketch(varName, tw, th, totalFrames, motionFX, arrayOutput, animTable);

  codeBox.value = `// Bitmap data only (${tw}x${th})\n\n${arrayOutput}${animTable}`;
  fullCodeBox.value = fullCode;

  switchTab('fullCode');
  if (isAnimActive) executeRenderLoopEngine();
}

function parseCanvasBytesToHexRowString(w, h, th) {
  const imgData = ctx.getImageData(0, 0, w, h); const data = imgData.data;
  let currentByte = 0, bitIndex = 0, collector = [];
  for (let y = 0; y < h; y++) {
    for (let x = 0; x < w; x++) {
      let idx = (y * w + x) * 4;
      let luminance = (0.2126 * data[idx] + 0.7152 * data[idx + 1] + 0.0722 * data[idx + 2]);
      if (luminance >= th) currentByte |= (1 << (7 - bitIndex));
      bitIndex++;
      if (bitIndex === 8) {
        collector.push('0x' + currentByte.toString(16).padStart(2, '0'));
        currentByte = 0; bitIndex = 0;
      }
    }
    if (bitIndex > 0) {
      collector.push('0x' + currentByte.toString(16).padStart(2, '0'));
      currentByte = 0; bitIndex = 0;
    }
  }
  let strOut = "";
  for (let i = 0; i < collector.length; i++) {
    strOut += collector[i];
    if (i < collector.length - 1) { strOut += ", "; if ((i + 1) % 16 === 0) strOut += "\n  "; }
  }
  return strOut;
}

// ========== CROP UI (image + video) ==========
cropToggleBtn.addEventListener('click', () => {
  const hasCroppable = (currentMode === 'video' && videoElement) || (currentMode !== 'video' && originalImage && gifFramesData.length === 0);
  if (!hasCroppable) return;
  if (isCropMode) disableCropModeUI(); else enableCropModeUI();
});

function enableCropModeUI() {
  isCropMode = true;
  clearInterval(activeRenderPlaybackInterval);
  cropToggleBtn.textContent = "⏏ Lock crop";
  cropToggleBtn.classList.add('btn-crop-active');
  canvas.style.display = 'none';
  cropBoxPro.style.display = 'block';

  if (currentMode === 'video' && videoElement) {
    srcVideoDisplay.style.display = 'block';
    srcImageDisplay.style.display = 'none';
  } else {
    srcImageDisplay.style.display = 'block';
    srcVideoDisplay.style.display = 'none';
  }
  updateCropOverlayUI();
}
function disableCropModeUI() {
  isCropMode = false;
  cropToggleBtn.textContent = "⌗ Precision crop";
  cropToggleBtn.classList.remove('btn-crop-active');
  cropBoxPro.style.display = 'none';
  srcImageDisplay.style.display = 'none';
  srcVideoDisplay.style.display = 'none';
  canvas.style.display = 'block';

  if (currentMode === 'video' && videoElement) {
    extractVideoFrames(); // re-sample using the new crop
  } else if (isAnimActive) {
    executeRenderLoopEngine();
  } else if (originalImage) {
    renderFrameToTargetResolution(originalImage);
  }
}
function updateCropOverlayUI() {
  cropBoxPro.style.top = cropMetrics.top + '%'; cropBoxPro.style.left = cropMetrics.left + '%';
  cropBoxPro.style.width = cropMetrics.width + '%'; cropBoxPro.style.height = cropMetrics.height + '%';
}
cropBoxPro.addEventListener('mousedown', (e) => {
  if (e.target.classList.contains('handle-pro')) { isResizing = true; activeResizeHandle = e.target.getAttribute('data-handle'); }
  else { isDragging = true; }
  startX = e.clientX; startY = e.clientY;
  const rect = workspaceContainer.getBoundingClientRect();
  startLeft = (cropBoxPro.offsetLeft / rect.width) * 100; startTop = (cropBoxPro.offsetTop / rect.height) * 100;
  startWidth = (cropBoxPro.offsetWidth / rect.width) * 100; startHeight = (cropBoxPro.offsetHeight / rect.height) * 100;
  e.preventDefault();
});
window.addEventListener('mousemove', (e) => {
  if (!isDragging && !isResizing) return;
  const rect = workspaceContainer.getBoundingClientRect();
  let dx = ((e.clientX - startX) / rect.width) * 100; let dy = ((e.clientY - startY) / rect.height) * 100;
  if (isDragging) {
    let l = startLeft + dx, t = startTop + dy;
    if (l < 0) l = 0; if (t < 0) t = 0;
    if (l + cropMetrics.width > 100) l = 100 - cropMetrics.width;
    if (t + cropMetrics.height > 100) t = 100 - cropMetrics.height;
    cropMetrics.left = l; cropMetrics.top = t;
  } else if (isResizing) {
    let h = activeResizeHandle;
    if (h.includes('r')) cropMetrics.width = Math.max(5, Math.min(startWidth + dx, 100 - cropMetrics.left));
    if (h.includes('b')) cropMetrics.height = Math.max(5, Math.min(startHeight + dy, 100 - cropMetrics.top));
    if (h.includes('l')) { let maxW = startLeft + startWidth; let targetL = Math.max(0, Math.min(startLeft + dx, maxW - 5)); cropMetrics.width = maxW - targetL; cropMetrics.left = targetL; }
    if (h.includes('t')) { let maxH = startTop + startHeight; let targetT = Math.max(0, Math.min(startTop + dy, maxH - 5)); cropMetrics.height = maxH - targetT; cropMetrics.top = targetT; }
  }
  updateCropOverlayUI();
});
window.addEventListener('mouseup', () => { isDragging = false; isResizing = false; });

// ========== SOURCE TAB SWITCH ==========
document.querySelectorAll('.source-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const incomingMode = tab.getAttribute('data-source');
    if (incomingMode === currentMode) return;

    document.querySelectorAll('.source-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.source-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');

    if (isCropMode) disableCropModeUI();
    clearInterval(activeRenderPlaybackInterval);

    snapshotCurrentMode(currentMode);
    currentMode = incomingMode;
    document.getElementById(`panel-${currentMode}`).classList.add('active');
    statusBar.style.display = 'none';

    if (currentMode !== 'video') {
      videoFrameCountField.style.display = 'none';
      videoScrubBar.classList.remove('show');
    }

    if (currentMode === 'text') {
      originalImage = null;
      gifFramesData = [];
      timelineFramesData = [];
      configPanel.classList.add('show');
      selectedBadge.textContent = 'Text mode';
      if (textInput.value.trim()) scheduleRender();
      else { placeholderText.style.display = 'block'; workspaceContainer.style.display = 'none'; }
      return;
    }

    // Non-text modes: try to restore prior content saved for this specific tab
    originalImage = null;
    gifFramesData = [];
    timelineFramesData = [];
    const restored = restoreMode(currentMode);

    if (currentMode === 'video') {
      if (videoElement && videoElement.duration && videoFramesExtracted.length) {
        placeholderText.style.display = 'none';
        workspaceContainer.style.display = 'block';
        configPanel.classList.add('show');
        videoFrameCountField.style.display = 'block';
        videoScrubBar.classList.add('show');
        if (isAnimActive) executeRenderLoopEngine();
        else renderFrameToTargetResolution(originalImage);
      } else {
        configPanel.classList.remove('show');
        placeholderText.style.display = 'block'; workspaceContainer.style.display = 'none';
      }
      return;
    }

    if (restored) {
      placeholderText.style.display = 'none';
      workspaceContainer.style.display = 'block';
      configPanel.classList.add('show');
      if (isAnimActive) executeRenderLoopEngine();
      else renderFrameToTargetResolution(originalImage);
    } else {
      configPanel.classList.remove('show');
      placeholderText.style.display = 'block'; workspaceContainer.style.display = 'none';
    }
  });
});

function switchTab(tabName) {
  document.querySelectorAll('.out-tab').forEach(t => t.classList.remove('active'));
  previewWrapper.style.display = 'none';
  codeWrapper.style.display = 'none';
  fullCodeWrapper.style.display = 'none';

  if (tabName === 'preview') {
    tabPreview.classList.add('active');
    previewWrapper.style.display = 'flex';
  } else if (tabName === 'code') {
    tabCode.classList.add('active');
    codeWrapper.style.display = 'flex';
  } else if (tabName === 'fullCode') {
    tabFullCode.classList.add('active');
    fullCodeWrapper.style.display = 'flex';
  }
}

